{
  "name": "rolldown-order-fuzzer",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vp exec node src/main.ts",
    "test": "vp test --run",
    "check": "vp check",
    "corpus:write": "vp exec node scripts/corpus-manifest.ts write corpus-manifest.golden.json",
    "corpus:check": "vp exec node scripts/corpus-manifest.ts check corpus-manifest.golden.json",
    "catching-power": "vp exec node scripts/catching-power.ts",
    "reacceptance": "vp exec node scripts/reacceptance.ts",
    "cross-entry-leak-catch": "vp exec node scripts/cross-entry-leak-catch.ts",
    "entries-aware-cycle-catch": "vp exec node scripts/entries-aware-cycle-catch.ts",
    "seo-false-sanity": "vp exec node scripts/seo-false-sanity.ts",
    "regression:redset": "vp exec node scripts/regression-redset.ts",
    "transplant:cell": "vp exec node scripts/transplant-cell.ts",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rolldown": "^1.1.4",
    "typescript": "^5.8.0",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
